{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests (last 5m)",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "stat",
      "title": "Error Rate (5xx %, 5m)",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "100 * (sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "stat",
      "title": "Active Borrows (success rate / 5m)",
      "id": 3,
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(library_borrow_total{status=\"success\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "stat",
      "title": "Cache Hit Ratio (5m)",
      "id": 4,
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "100 * sum(rate(library_cache_events_total{event=\"hit\"}[5m])) / clamp_min(sum(rate(library_cache_events_total{event=~\"hit|miss\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Request rate by status",
      "id": 5,
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Latency p50/p95/p99",
      "id": 6,
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Auth attempts",
      "id": 7,
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(library_auth_attempts_total[1m])) by (event, result)",
          "legendFormat": "{{event}}/{{result}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Borrow / Return events",
      "id": 8,
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(library_borrow_total[1m])) by (status)",
          "legendFormat": "borrow/{{status}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(library_return_total[1m]))",
          "legendFormat": "return",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["library", "fastapi"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Library Management — Overview",
  "uid": "library-overview",
  "version": 1,
  "weekStart": ""
}
